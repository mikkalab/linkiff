          "_name": "content4",
          "_customHTML": "<section class=\"mbr-section content4\" group=\"Article\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"0\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"3\">\n\n        <input type=\"checkbox\" title=\"Show Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Show Subtitle\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Show Buttons\" name=\"showButtons\">\n        <input type=\"color\" title=\"Background Color\" name=\"bgColor\" value=\"#ffffff\">\n    <!-- End block parameters -->\n    </mbr-parameters>\n\n    <div class=\"container\">\n        <div class=\"media-container-row\">\n            <div class=\"title col-12 col-md-8\">\n                <h2 mbr-if=\"showTitle\" class=\"align-center pb-3 mbr-fonts-style\" mbr-theme-style=\"display-2\">WEST EUROPE SHORT FILM &nbsp;</h2>\n                <h3 mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" class=\"mbr-section-subtitle align-center mbr-light mbr-fonts-style\" mbr-theme-style=\"display-7\">MY BORDER MY FOREST - Directed by Giorgio Milocco, Italy\n<div>UNCONDITIONAL - Directed by Johannes Ziegler, Germany\n</div><div>REISE NACH NIRGENDWO - Directed by Thomas Scherer, Germany\n</div><div>ARTEM SILENDI - Directed by Frank Ychou, France\n</div><div>SALEM - Directed by Sophie Beaulieu, France\n</div><div>PERLA MADRE - Directed by Mauro Morandini, Davide Maimone, Italy\n</div><div>THE LITTLE SHAME - Directed by Zahra Benasri, Belgium\n</div><div>OGRE- Directed by Herminio Cardiel, Spain\n</div><div>A ROLL IN THE HAY - Directed by Geoffrey Fighiera, France\n</div><div>PARIS 2024 - Directed by Pierre Larribe, France\n</div><div>JOIN ME - Directed by Anaïs Nativel, France\n</div><div>SUSPENSION BRIDGE - Directed by Raghu Kondori, France\n</div><div>PREFERENTES- Directed by Nacho Recio, Spain\n</div><div>A WORLD FREE OF CRISIS - Directed by Ted Hardy-Carnac, France\n</div><div>MOON POISON - Directed by Sébastien Cassen, France\n</div><div>SO LONG, PARIS! - Directed by Charles Dudoignon-Valade, France\n</div><div>THE TAXI DEAD- Directed by Simon Lahm, Germany\n</div><div>JUST LIKE WATER - Directed by Manos Triantafillakis, Greece\n</div><div>BURN THE TIME - Directed by Rasim Asan, Belgium\n</div><div>HORIZON- Directed by Daniele De Muro, Italy\n</div><div>ME AND MYSELF- Directed by Passos Zamith, Portugal\n</div><div>PERSISTENT DISTURBANCE - Directed by Laurien Bachmann, Sebastian Six\n</div><div>ZAWAL - Directed by Mujtaba Saeed, Germany\n</div><div>THE RECESS - Directed by Navid Nikkhah Azad, Spain</div></h3>\n                <div class=\"mbr-section-btn align-center py-4\" mbr-if=\"showButtons\" mbr-buttons mbr-theme-style=\"display-4\">\n                    <a class=\"btn btn-primary\" href=\"https://mobirise.co\">LEARN MORE</a>\n                    <a class=\"btn btn-black-outline\" href=\"https://mobirise.co\">LIVE DEMO</a>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
