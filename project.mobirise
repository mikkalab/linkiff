          },
          "_name": "content4",
          "_customHTML": "<section class=\"mbr-section content4\" group=\"Article\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"4\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"0\">\n\n        <input type=\"checkbox\" title=\"Show Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Show Subtitle\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Show Buttons\" name=\"showButtons\">\n        <input type=\"color\" title=\"Background Color\" name=\"bgColor\" value=\"#ffffff\">\n    <!-- End block parameters -->\n    </mbr-parameters>\n\n    <div class=\"container\">\n        <div class=\"media-container-row\">\n            <div class=\"title col-12 col-md-8\">\n                <h2 mbr-if=\"showTitle\" class=\"align-center pb-3 mbr-fonts-style\" mbr-theme-style=\"display-2\">OFFICIAL SELECTION&nbsp;</h2>\n                <h3 mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" class=\"mbr-section-subtitle align-center mbr-light mbr-fonts-style\" mbr-theme-style=\"display-5\">FATHER – Lella Satie, Canada\n<div>MOVING IN CIRCLES – Maxim Dashkin, Russia\n</div><div>CITIPATI - Andreas Feix, Gernamy\n</div><div>IN THE STARS – Ayo J. Sanusi, UK\n</div><div>SHOOTING STAR – Lyubo Yonchev, Bulgaria\n</div><div>I’VE JUST HAD A DREAM – Javi Navarro, Spain\n</div><div>THE JUNCTION – Xhelal Haliti, Kosovo\n</div><div>KING GRANDPA – Martin Grau, Germany\n</div><div>A RIDE HOME – Sivaraj Pragasm, Singapore\n</div><div>MOTUS – Oton Bacar, Slovenia\n</div><div>SHOWTIME – Conor Boru, UK\n</div><div>TRUE COLORS - Nicole Morciniec, USA\n</div><div>THE LAST ONE – Andrea Banjanin, UK\n</div><div>THE GUILT LIST – Tereza Hirsch, Czech Republic\n</div><div>THOU SHALT NOT LIE – Sascha Zimmermann, Germany\n</div><div>CANDIE BOY – Arianna Del Grosso, Italy\n</div><div>ACE – A. D. Cooper, UK\n</div><div>MY LIFE I DON’T WANT - Nyan Kyal Say, Maynmar\n</div><div>INTERCEPTION – Jesper Emborg, UK\n</div><div>PERFECT FIT – Vladimir Stanishevskii, Russia\n</div><div>HOBLIO – Piero Tonin, Italy\n</div><div>FOLEY ARTIST – Tony Bestard, Spain\n</div><div>LURNA – Nani Matos, Spain\n</div><div>WAFAA - Ilham El Alami, Morocco\n</div><div>LOST IN HOPE – Aline Hochscheid, Germany / Israel\n</div><div>NICE JOB - Tigran Sahakyan, Russia\n</div><div>A VAGABOND WIND - Enamul Haque Khan, Italy\n</div><div>CONVERSATION ON LIFE – Agim Abdula, Macedonia\n</div><div>UNMASKED – Alice Gavish / Christina Faraj, USA / Israel\n</div><div>BACKSTORY - Joschka Laukeninks, Germany\n</div><div>PAPER PLANE - Joey Lever, UK\n</div><div>BEYOND THE BORDER - Daniele Lucca, Italy\n</div><div>LIGHT SIGHT – Seyed M. Tabatabaei, Iran\n</div><div>HOME – Simona Feldman, Germany\n</div><div>SAABIR - Amjad Ali Khan, Pakistan\n</div><div>A LONG TIME AGO IN SILESIA - Tomasz Protokowich, Poland\n</div><div>IN THE STARS – Ayo J. Sanusi, UK\n</div><div>NGALANGALA – Tom Johns, Tanzania\n</div><div>RUYA – Alper Akdeniz, Turkey\n</div><div>GORILLA – Tibo Pinsard, France\n</div><div>WHERE HAVE THE FLOWERS GONE – Sin-hong Chan, Hong Kong\n</div><div>AT THE BORDER – Laurent Rouy, Serbia\n</div><div>THE BOX – Merve Cirisoglu Cotur, UK\n</div><div>THE SCHOOL BAG – Dheeraj Jindal, India\n</div><div>THIRSTY CHILDREN – Rzgar husen, Iraq\n</div><div>LOVE IS BLIND – Sabine Crossen, France\n</div><div>THE BORDER – Norman Tamkivi, UK\n</div><div>THE CLOCK IS TICKING - Marcin Zbyszynski, Poland\n</div><div>THE CHOP – Lewis Rose, UK\n</div><div>JOURNEY – Radheya Jegatheva, Australia\n</div><div>SOLVEIG – Yana Titova, Bulgaria\n</div><div>IN PLACE – Eelke Dekker, Germany\n</div><div>MY HAPPINESS – Semagngeta Aychiluhem, Ethiopia\n</div><div>INFINITE – Connor O’Hara, UK\n</div></h3>\n                <div class=\"mbr-section-btn align-center py-4\" mbr-if=\"showButtons\" mbr-buttons mbr-theme-style=\"display-4\">\n                    <a class=\"btn btn-primary\" href=\"https://mobirise.co\">LEARN MORE</a>\n                    <a class=\"btn btn-black-outline\" href=\"https://mobirise.co\">LIVE DEMO</a>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
